# Bazel configuration for envoy-socks5-filter

# Use C++17
build --cxxopt=-std=c++17
build --host_cxxopt=-std=c++17

# Optimization
build --compilation_mode=opt

# Use Clang on macOS
build:macos --host_cxxopt=-std=c++17
build:macos --cxxopt=-stdlib=libc++
build:macos --host_cxxopt=-stdlib=libc++

# Linux config
build:linux --copt=-fPIC
build:linux --linkopt=-fPIC

# Remote build (GitHub Actions)
build:ci --remote_cache=grpcs://remotebuildexecution.googleapis.com
build:ci --google_default_credentials
build:ci --jobs=32

# Debug config
build:debug --compilation_mode=dbg
build:debug -c dbg

# Address sanitizer
build:asan --config=clang-asan
build:asan --copt=-g
build:asan --copt=-fno-omit-frame-pointer

# Test configuration
test --test_output=errors
test --test_verbose_timeout_warnings

# Silence warnings from external dependencies
build --per_file_copt=external/.*@-w
build --host_per_file_copt=external/.*@-w
